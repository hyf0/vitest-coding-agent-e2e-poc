# Claude Code — set ONE of these:
#   ANTHROPIC_API_KEY: API key from console.anthropic.com. Pay-per-use billing.
#   CLAUDE_CODE_OAUTH_TOKEN: Subscription-backed token (Pro/Max/Team/Enterprise).
#     Generate once with `claude setup-token` (opens browser OAuth flow),
#     then paste the resulting token here. Valid for 1 year.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Codex — set ONE of these:
#   CODEX_API_KEY: API key for codex exec. Pay-per-use billing via platform.openai.com.
#   OPENAI_API_KEY: Also works, but CODEX_API_KEY is preferred for non-interactive use.
#   For subscription-based auth (ChatGPT Plus/Pro/Business), use `codex login` interactively
#   or `codex login --device-auth` (beta, requires workspace admin to enable).
CODEX_API_KEY=
OPENAI_API_KEY=
